# Environment Variables for Fameko Delivery System
# Copy this file to .env for local development
# For Render deployment, set these in the Render dashboard

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-in-production

# Database (Render provides this automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# Google Maps API (Required for geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Email Configuration (Optional - for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=delivery-system@example.com

# Routing Services (Set in render.yaml for internal communication)
ROUTING_SERVICE_URL=http://fameko-routing-go:8080
ROUTING_SERVICE_PYTHON_URL=http://fameko-routing-python:5001
LIVE_LOCATION_SERVICE_URL=http://fameko-routing-python:5001

# Redis (Render provides this automatically)
REDIS_URL=redis://host:port
SOCKETIO_MESSAGE_QUEUE=redis://host:port

# CORS Configuration
CORS_ORIGINS=*
